{
    "name": "tomahock/laravel-cloudflare-mail",
    "description": "Laravel mail driver for Cloudflare Email Service",
    "type": "library",
    "keywords": ["laravel", "cloudflare", "mail", "email", "transactional"],
    "license": "MIT",
    "authors": [
        {
            "name": "Tomahock",
            "email": "eu@tomahock.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "symfony/mailer": "^6.0|^7.0",
        "symfony/mime": "^6.0|^7.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Tomahock\\CloudflareMail\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tomahock\\CloudflareMail\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Tomahock\\CloudflareMail\\CloudflareMailServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
